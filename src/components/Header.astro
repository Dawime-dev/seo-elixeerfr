---
import siteConfig from '../../site.config.json';

const categories = siteConfig.categories || [];

const navLinks = [
  { label: 'Contact', href: '/contact' },
  { label: 'Ressources', href: '/ressources-gratuites' }
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b border-slate-800/80 bg-slate-950/90 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Scalr - Accueil">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center shadow-lg shadow-indigo-500/25">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
            <polyline points="16 7 22 7 22 13"/>
          </svg>
        </div>
        <span class="text-xl font-extrabold text-white tracking-tight group-hover:text-indigo-400 transition-colors">
          {siteConfig.name}
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">

        <!-- Catégories dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800/60 rounded-lg transition-all"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Catégories
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>

          <!-- Dropdown menu -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-72 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
            <div class="bg-slate-900 border border-slate-700/80 rounded-2xl shadow-xl shadow-black/40 p-2 overflow-hidden">
              {categories.map((cat: { name: string; slug: string; description: string }) => (
                <a
                  href={`/categorie/${cat.slug}`}
                  class={`flex flex-col gap-0.5 px-4 py-3 rounded-xl transition-all hover:bg-slate-800/80 ${
                    currentPath.includes(cat.slug) ? 'bg-indigo-600/20 text-indigo-300' : 'text-slate-300'
                  }`}
                >
                  <span class="font-semibold text-sm text-white">{cat.name}</span>
                  <span class="text-xs text-slate-400 line-clamp-1">{cat.description}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Pages pilier -->
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm font-medium rounded-lg transition-all ${
              currentPath === link.href
                ? 'text-white bg-slate-800'
                : 'text-slate-300 hover:text-white hover:bg-slate-800/60'
            }`}
          >
            {link.label}
          </a>
        ))}

        <!-- CTA -->
        <a
          href="/ressources-gratuites"
          class="ml-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-all shadow-lg shadow-indigo-600/20 hover:shadow-indigo-500/30"
        >
          Démarrer →
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800 transition-all"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="6" y2="6"/>
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/>
          <path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-slate-800/80 bg-slate-950"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">

      <p class="px-3 py-1 text-xs font-semibold text-slate-500 uppercase tracking-widest">Catégories</p>
      {categories.map((cat: { name: string; slug: string; description: string }) => (
        <a
          href={`/categorie/${cat.slug}`}
          class="flex items-center gap-3 px-3 py-3 text-slate-300 hover:text-white hover:bg-slate-800/60 rounded-xl transition-all"
        >
          <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
          <span class="font-medium text-sm">{cat.name}</span>
        </a>
      ))}

      <div class="h-px bg-slate-800 my-3"></div>

      <p class="px-3 py-1 text-xs font-semibold text-slate-500 uppercase tracking-widest">Pages</p>
      {navLinks.map(link => (
        <a
          href={link.href}
          class="flex items-center gap-3 px-3 py-3 text-slate-300 hover:text-white hover:bg-slate-800/60 rounded-xl transition-all text-sm font-medium"
        >
          {link.label}
        </a>
      ))}

      <div class="pt-2">
        <a
          href="/ressources-gratuites"
          class="flex items-center justify-center w-full px-4 py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-all"
        >
          Démarrer →
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
