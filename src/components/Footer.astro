---
import siteConfig from '../../site.config.json';

const categories = siteConfig.categories || [];
const currentYear = new Date().getFullYear();

const staticLinks = [
  { label: 'Contact', href: '/contact' },
  { label: 'Ressources gratuites', href: '/ressources-gratuites' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Politique de confidentialité', href: '/confidentialite' }
];
---

<footer class="bg-slate-900 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
              <polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <span class="text-xl font-extrabold text-white">{siteConfig.name}</span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed max-w-sm mb-6">
          {siteConfig.description}
        </p>
        <div class="flex items-center gap-3">
          <a
            href="/contact"
            class="px-4 py-2 text-sm font-semibold text-slate-300 border border-slate-700 hover:border-slate-500 hover:text-white rounded-xl transition-all"
          >
            Nous contacter
          </a>
          <a
            href="/ressources-gratuites"
            class="px-4 py-2 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 rounded-xl transition-all"
          >
            Ressources gratuites
          </a>
        </div>
      </div>

      <!-- Catégories -->
      <div>
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-5">Catégories</h3>
        <ul class="space-y-3">
          {categories.map((cat: { name: string; slug: string }) => (
            <li>
              <a
                href={`/categorie/${cat.slug}`}
                class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group"
              >
                <span class="w-1 h-1 rounded-full bg-indigo-500 group-hover:w-2 transition-all"></span>
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Liens rapides -->
      <div>
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-5">Liens rapides</h3>
        <ul class="space-y-3">
          {staticLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group"
              >
                <span class="w-1 h-1 rounded-full bg-indigo-500 group-hover:w-2 transition-all"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">
        © {currentYear} <span class="text-slate-400 font-medium">{siteConfig.name}</span>. Tous droits réservés.
      </p>
      <p class="text-sm text-slate-600">
        <a href={siteConfig.url} class="hover:text-slate-400 transition-colors">{siteConfig.url.replace('https://', '')}</a>
      </p>
    </div>
  </div>
</footer>
